# MongoDB Connection
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/writewisely

# JWT Configuration
JWT_SECRET=your-secret-key-here-min-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# LLM API - OpenRouter (Primary)
OPENROUTER_API_KEY=your-openrouter-api-key-here
LLM_MODEL=google/gemma-3-12b-it:free

# LLM API - Google Gemini (Fallback)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Email Configuration (Optional)
MAILERSEND_API_KEY=your-mailersend-api-key
MAILERSEND_DOMAIN=your-domain.com
SENDER_EMAIL=noreply@your-domain.com
SENDER_NAME=WriteWisely
